Value Required NAME (\S.*?)
Value DESCRIPTION (\S.*?)
Value TRANSLATION_SOURCE_OBJECT (easy-ip|\S.*\S)
Value STATIC_MODE (address-to-address|address-to-port|port-to-address|port-to-port)
Value TRANSLATION_DESTINATION_ADDRESS (\d+\.\d+\.\d+\.\d+)
Value TRANSLATION_DESTINATION_OBJECT (\S.*\S)
Value TRANSLATION_DESTINATION_PORT (\d+.*\d+)
Value NO_NAT (no-nat)
Value TIME_RANGE (\S.*\S)
Value EGRESS_INTERFACE (\S+)
Value STATUS (enable|disable)
Value List SOURCE_ZONE (\S+)
Value List DESTINATION_ZONE (\S+)
Value List SOURCE_ADDRESS (\S.*\S)
Value List SOURCE_OBJECT (\S.*\S)
Value List DESTINATION_ADDRESS (\S.*\S)
Value List DESTINATION_OBJECT (\S.*\S)
Value List SERVICE (\S.*\S)

Start
  ^\s*rule name -> Continue.Record
  ^\s*rule name ${NAME}
  ^\s*description ${DESCRIPTION}
  ^\s*source-zone ${SOURCE_ZONE}
  ^\s*destination-zone ${DESTINATION_ZONE}
  ^\s*source-address\s+address-set\s+${SOURCE_OBJECT}
  ^\s*source-address\s+${SOURCE_ADDRESS}
  ^\s*destination-address\s+address-set\s+${DESTINATION_OBJECT}
  ^\s*destination-address\s+${DESTINATION_ADDRESS}
  ^\s*service ${SERVICE}
  ^\s*time-range ${TIME_RANGE}
  ^\s*action\s+source-nat(\s+address-group)?\s+${TRANSLATION_SOURCE_OBJECT}
  ^\s*action\s+destination-nat(\s+static\s+${STATIC_MODE})?(\s+address\s+${TRANSLATION_DESTINATION_ADDRESS})?(\s+address-group\s+${TRANSLATION_DESTINATION_OBJECT})?(\s+${TRANSLATION_DESTINATION_PORT})?
  ^\s*action\s+${NO_NAT}
  ^\s*${STATUS}
  ^\s*egress-interface ${EGRESS_INTERFACE}
  ^.* -> Start